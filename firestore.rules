rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    match /amiri_settings/{settingId} {
      // Anyone can read and write the global images, logo, services and projects in the preview environment
      allow read, write: if true;
    }
  }
}
