rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    match /amiri_settings/{settingId} {
      // Anyone can read the global images/logo
      allow read: if true;
      // Only the authenticated site owner can update global settings
      allow write: if request.auth != null && (
        request.auth.token.email.toLowerCase() == "info@amiribygg.no" ||
        request.auth.token.email.toLowerCase() == "mizhgan.amiri83@gmail.com"
      );
    }
  }
}
